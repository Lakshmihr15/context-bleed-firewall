{
  "manifest_version": 3,
  "name": "Pacific Context Collector",
  "version": "1.0",
  "description": "Captures text box inputs for the Pacific Context Graph",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://pacific-context-bleed-firewall.onrender.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
